[{"Word":"abase","Definitions":[{"Partofspeech":"verb","Meaning":"to humiliate, degrade","Sentence":"After being overthrown and abased, the deposed leader offered to bow down to his conqueror."}]},{"Word":"abate","Definitions":[{"Partofspeech":"verb","Meaning":"to reduce, lessen","Sentence":"The rain poured down for a while, then abated."}]},{"Word":"abdicate","Definitions":[{"Partofspeech":"verb","Meaning":" to give up a position, usually one of leadership","Sentence":"When he realized that the revolutionaries would surely win, the king abdicated his throne."}]},{"Word":"abduct","Definitions":[{"Partofspeech":"verb","Meaning":"to kidnap, take by force","Sentence":"The evildoers abducted the fairy princess from her happy home."}]},{"Word":"aberration","Definitions":[{"Partofspeech":"noun","Meaning":"something that differs from the norm ","Sentence":"In 1918, the Boston Red Sox won the World Series, but the success turned out to be an aberration, and the Red Sox have not won a World Series since."}]},{"Word":"abet","Definitions":[{"Partofspeech":"verb","Meaning":"to aid, help, encourage","Sentence":"The spy succeeded only because he had a friend on the inside to abet him."}]},{"Word":"abhor","Definitions":[{"Partofspeech":"verb","Meaning":"to hate, detest","Sentence":"Because he always wound up kicking himself in the head when he tried to play soccer, Oswald began to abhor the sport."}]},{"Word":"abide ","Definitions":[{"Partofspeech":"verb","Meaning":"to put up with ","Sentence":"Though he did not agree with the decision, Chuck decided to abide by it."}]},{"Word":"abject","Definitions":[{"Partofspeech":"adjective","Meaning":"wretched, pitiful","Sentence":"After losing all her money, falling into a puddle, and breaking her ankle, Eloise was abject."}]},{"Word":"abjure","Definitions":[{"Partofspeech":"verb","Meaning":"to reject, renounce","Sentence":"To prove his honesty, the President abjured the evil policies of his wicked predecessor."}]},{"Word":"abnegation ","Definitions":[{"Partofspeech":"noun","Meaning":"denial of comfort to oneself ","Sentence":"The holy man slept on the floor, took only cold showers, and generally followed other practices of abnegation."}]},{"Word":"abort","Definitions":[{"Partofspeech":"verb","Meaning":"to give up on a half-finished project or effort","Sentence":"After they ran out of food, the men, attempting to jump rope around the world, had to abort and go home."}]},{"Word":"abridge","Definitions":[{"Partofspeech":"verb","Meaning":"to cut down, shorten ","Sentence":"The publisher thought the dictionary was too long and abridged it."}]},{"Word":"abrogate","Definitions":[{"Partofspeech":"verb","Meaning":"to abolish, usually by authority","Sentence":"The Bill of Rights assures that the government cannot abrogate our right to a free press."}]},{"Word":"abscond","Definitions":[{"Partofspeech":"verb","Meaning":"to sneak away and hide","Sentence":"In the confusion, the super-spy absconded into the night with the secret plans."}]},{"Word":"absolution","Definitions":[{"Partofspeech":"noun","Meaning":"freedom from blame, guilt, sin","Sentence":"Once all the facts were known, the jury"}]},{"Word":"abstain","Definitions":[{"Partofspeech":"verb","Meaning":"to freely choose not to commit an action ","Sentence":"Everyone demanded that Angus put on the kilt, but he did not want to do it and abstained."}]},{"Word":"abstruse","Definitions":[{"Partofspeech":"adjective","Meaning":"hard to comprehend","Sentence":"Everyone else in the class understood geometry easily, but John found the subject abstruse."}]},{"Word":"accede","Definitions":[{"Partofspeech":"verb","Meaning":"to agree","Sentence":"When the class asked the teacher whether they could play baseball instead of learn grammar they expected him to refuse, but instead he acceded to their request."}]},{"Word":"accentuate","Definitions":[{"Partofspeech":"verb","Meaning":"to stress, highlight","Sentence":"Psychologists agree that those people who are happiest accentuate the positive in life."}]}]