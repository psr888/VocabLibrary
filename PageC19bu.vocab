[{"Word":"connive","Definitions":[{"Partofspeech":"verb","Meaning":" to plot, scheme","Sentence":"She connived to get me to give up my vacation plans."}]},{"Word":"consecrate","Definitions":[{"Partofspeech":"verb","Meaning":"to dedicate something to a holy purpose","Sentence":"Arvin consecrated his spare bedroom as a shrine to Christina."}]},{"Word":"consensus","Definitions":[{"Partofspeech":"noun","Meaning":"an agreement of opinion","Sentence":"The jury was able to reach a consensus only after days of deliberation."}]},{"Word":"consign","Definitions":[{"Partofspeech":"verb","Meaning":"to give something over to another’s care","Sentence":"Unwillingly, he consigned his mother to a nursing home."}]},{"Word":"consolation","Definitions":[{"Partofspeech":"noun","Meaning":"an act of comforting","Sentence":"Darren found Alexandra’s presence to be a consolation for his suffering."}]},{"Word":"consonant","Definitions":[{"Partofspeech":"adj","Meaning":"in harmony","Sentence":"The singers’ consonant voices were beautiful"}]},{"Word":"constituent","Definitions":[{"Partofspeech":"noun","Meaning":"an essential part","Sentence":"The most important constituent of her perfume is something called ambergris."}]},{"Word":"constrain","Definitions":[{"Partofspeech":"verb","Meaning":"to forcibly restrict","Sentence":"His belief in nonviolence constrained him from taking revenge on his attackers."}]},{"Word":"construe","Definitions":[{"Partofspeech":"verb","Meaning":"to interpret","Sentence":"He construed her throwing his clothes out the window as a signal that she wanted him to leave."}]},{"Word":"consummate","Definitions":[{"Partofspeech":"verb","Meaning":"to complete a deal; to complete a marriage ceremony through sexual intercourse","Sentence":"Erica and Donald consummated their agreement in the executive boardroom."}]},{"Word":"consumption","Definitions":[{"Partofspeech":"noun","Meaning":" the act of consuming","Sentence":"Consumption of intoxicating beverages is not permitted on these premises."}]},{"Word":"contemporaneous ","Definitions":[{"Partofspeech":"adj","Meaning":"existing during the same time","Sentence":"Though her novels do not feature the themes of Romanticism, Jane Austen’s work was contemporaneous with that of Wordsworth and Byron."}]},{"Word":"contentious","Definitions":[{"Partofspeech":"adj","Meaning":"having a tendency to quarrel or dispute","Sentence":"George’s contentious personality made him unpopular with his classmates."}]},{"Word":"contravene","Definitions":[{"Partofspeech":"verb","Meaning":"to contradict, oppose, violate","Sentence":"Edwidge contravened his landlady’s rule against overnight guests."}]},{"Word":"contrite","Definitions":[{"Partofspeech":"adj","Meaning":"penitent, eager to be forgiven","Sentence":"Blake’s contrite behavior made it impossible to stay angry at him."}]},{"Word":"contusion","Definitions":[{"Partofspeech":"noun","Meaning":" bruise, injury","Sentence":"The contusions on his face suggested he’d been in a fight."}]}]