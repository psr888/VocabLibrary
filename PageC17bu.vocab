[{"Word":"coalesce","Definitions":[{"Partofspeech":"verb","Meaning":" to fuse into a whole","Sentence":"Gordon’s ensemble of thrift-shop garments coalesced into a surprisingly handsome outfit."}]},{"Word":"cobbler","Definitions":[{"Partofspeech":"noun","Meaning":"a person who makes or repairs shoes","Sentence":"I had my neighborhood cobbler replace my worn-out leather soles with new ones."}]},{"Word":"coerce ","Definitions":[{"Partofspeech":"verb","Meaning":"to make somebody do something by force or threat","Sentence":"The court decided that Vanilla Ice did not have to honor the contract because he had been coerced into signing it."}]},{"Word":"cogent","Definitions":[{"Partofspeech":"adjective","Meaning":"intellectually convincing","Sentence":"Irene’s arguments in favor of abstinence were so cogent that I could not resist them."}]},{"Word":"cognizant","Definitions":[{"Partofspeech":"adjective","Meaning":"aware, mindful","Sentence":"Jake avoided speaking to women in bars because he was cognizant of the fact that drinking impairs his judgment."}]},{"Word":"coherent","Definitions":[{"Partofspeech":"adjective","Meaning":"logically consistent, intelligible","Sentence":"Renee could not figure out what Monroe had seen because he was too distraught to deliver a coherent statement."}]},{"Word":"collateral","Definitions":[{"Partofspeech":"adjective","Meaning":"secondary","Sentence":"Divorcing my wife had the collateral effect of making me poor, as she was the only one of us with a job or money."},{"Partofspeech":"noun","Meaning":"security for a debt ","Sentence":"Jacob left his watch as collateral for the $500 loan."}]},{"Word":"colloquial","Definitions":[{"Partofspeech":"adjective","Meaning":"characteristic of informal conversation","Sentence":"Adam’s essay on sexual response in primates was marked down because it contained too many colloquial expressions."}]},{"Word":"collusion","Definitions":[{"Partofspeech":"noun","Meaning":"secret agreement, conspiracy","Sentence":"The three law students worked in collusion to steal the final exam."}]},{"Word":"colossus ","Definitions":[{"Partofspeech":"noun","Meaning":"a gigantic statue or thing ","Sentence":"For 56 years, the ancient city of Rhodes featured a colossus standing astride its harbor."}]},{"Word":"combustion ","Definitions":[{"Partofspeech":"noun","Meaning":" the act or process of burning","Sentence":"The unexpected combustion of the prosecution’s evidence forced the judge to dismiss the case against Ramirez."}]},{"Word":"commendation","Definitions":[{"Partofspeech":"noun","Meaning":"a notice of approval or recognition","Sentence":"Jared received a commendation from Linda, his supervisor, for his stellar performance."}]},{"Word":"commensurate","Definitions":[{"Partofspeech":"adjective","Meaning":"corresponding in size or amount ","Sentence":"Ahab selected a very long roll and proceeded to prepare a tuna salad sandwich commensurate with his enormous appetite."}]},{"Word":"commodious ","Definitions":[{"Partofspeech":"adjective","Meaning":"roomy","Sentence":"Holden invited the three women to join him in the back seat of the taxicab, assuring them that the car was quite commodious."}]},{"Word":"compelling","Definitions":[{"Partofspeech":"adjective","Meaning":"forceful, demanding attention","Sentence":"Eliot’s speech was so compelling that Lenore accepted his proposal on the spot."}]},{"Word":"compensate ","Definitions":[{"Partofspeech":"verb","Meaning":"to make an appropriate payment for something","Sentence":"Reginald bought Sharona a new dress to compensate her for the one he’d spilled his ice cream on."}]},{"Word":"complacency","Definitions":[{"Partofspeech":"noun","Meaning":"self-satisfied ignorance of danger ","Sentence":"Colin tried to shock his friends out of their complacency by painting a frightening picture of what might happen to them."}]},{"Word":"complement ","Definitions":[{"Partofspeech":"verb","Meaning":"to complete, make perfect ","Sentence":"Ann’s scarf complements her blouse beautifully, making her seem fully dressed even though she isn’t wearing a coat."}]},{"Word":"complacency ","Definitions":[{"Partofspeech":"noun","Meaning":"self-satisfied ignorance of danger","Sentence":"Colin tried to shock his friends out of their complacency by painting a frightening picture of what might happen to them."}]},{"Word":"complement","Definitions":[{"Partofspeech":"verb","Meaning":" to complete, make perfect","Sentence":"Ann’s scarf complements her blouse beautifully, making her seem fully dressed even though she isn’t wearing a coat."}]},{"Word":"compliant","Definitions":[{"Partofspeech":"adjective","Meaning":"ready to adapt oneself to another’s wishes ","Sentence":"Sue had very strong opinions about what to do on a first date, and Ted was absolutely compliant."}]},{"Word":"complicit","Definitions":[{"Partofspeech":"adjective","Meaning":"being an accomplice in a wrongful act","Sentence":"By keeping her daughter’s affair a secret, Maddie became complicit in it."}]},{"Word":"compliment","Definitions":[{"Partofspeech":"noun","Meaning":" an expression of esteem or approval ","Sentence":"I blushed crimson when Emma gave me a compliment on my new haircut."}]},{"Word":"compound","Definitions":[{"Partofspeech":"verb","Meaning":"to combine parts ","Sentence":"The difficulty of finding a fire escape amid the smoke was compounded with the dangers posed by the panicking crowds."},{"Partofspeech":"noun","Meaning":"a combination of different parts","Sentence":"My attraction to Donna was a compound of curiosity about the unknown, physical desire, and intellectual admiration."},{"Partofspeech":"noun","Meaning":"a walled area containing a group of buildings ","Sentence":"When the fighting started, Joseph rushed into the family compound because it was safe and well defended."}]},{"Word":"comprehensive","Definitions":[{"Partofspeech":"adjective","Meaning":"including everything ","Sentence":"She sent me a comprehensive list of the ingredients needed to cook rabbit soufflé."}]},{"Word":"compress ","Definitions":[{"Partofspeech":"verb","Meaning":"to apply pressure, squeeze together","Sentence":"Lynn compressed her lips into a frown."}]},{"Word":"compunction","Definitions":[{"Partofspeech":"noun","Meaning":"distress caused by feeling guilty","Sentence":"He felt compunction for the shabby way he’d treated her."}]},{"Word":"concede","Definitions":[{"Partofspeech":"verb","Meaning":"to accept as valid","Sentence":"Andrew had to concede that what his mother said about Diana made sense."}]},{"Word":"conciliatory","Definitions":[{"Partofspeech":"adjective","Meaning":"friendly, agreeable ","Sentence":"I took Amanda’s invitation to dinner as a very conciliatory gesture."}]}]