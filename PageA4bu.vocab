[{"Word":"adhere","Definitions":[{"Partofspeech":"noun","Meaning":"to stick to something","Sentence":"We adhered the poster to the wall with tape."}]},{"Word":"admonish","Definitions":[{"Partofspeech":"verb","Meaning":"to caution, criticize, reprove","Sentence":"Joe’s mother admonished him not to ruin his appetite by eating cookies before dinner."}]},{"Word":"adorn","Definitions":[{"Partofspeech":"verb","Meaning":"to decorate","Sentence":"We adorned the tree with ornaments."}]},{"Word":"adroit","Definitions":[{"Partofspeech":"adjective","Meaning":"skillful, dexterous","Sentence":"The adroit thief could pick someone’s pocket without attracting notice."}]},{"Word":"adulation ","Definitions":[{"Partofspeech":"noun","Meaning":"to sketch out in a vague way","Sentence":"The coach adumbrated a game plan, but none of the players knew precisely what to do."}]},{"Word":"adverse","Definitions":[{"Partofspeech":"adjective","Meaning":"antagonistic, unfavorable, dangerous","Sentence":"Because of adverse conditions, the hikers decided to give up trying to climb the mountain."}]},{"Word":"advocate","Definitions":[{"Partofspeech":"verb","Meaning":"to argue in favor of something","Sentence":"Arnold advocated turning left at the stop sign, even though everyone else thought we should turn right."}]},{"Word":"aerial","Definitions":[{"Partofspeech":"adjective","Meaning":"somehow related to the air","Sentence":"We watched as the fighter planes conducted aerial maneuvers"}]},{"Word":"aesthetic","Definitions":[{"Partofspeech":"adj","Meaning":"artistic, related to the appreciation of beauty ","Sentence":"We hired Susan as our interior decorator because she has such a fine aesthetic sense."}]},{"Word":"affable ","Definitions":[{"Partofspeech":"adj","Meaning":"friendly, amiable","Sentence":"People like to be around George because he is so affable and good-natured."}]},{"Word":"affinity","Definitions":[{"Partofspeech":"noun","Meaning":"a spontaneous feeling of closeness ","Sentence":"Jerry didn’t know why, but he felt an incredible affinity for Kramer the first time they met."}]},{"Word":"affluent","Definitions":[{"Partofspeech":"adj","Meaning":"rich, wealthy","Sentence":"Mrs. Grebelski was affluent, owning a huge house, three cars, and an island near Maine."}]},{"Word":"affront","Definitions":[{"Partofspeech":"noun","Meaning":"an insult","Sentence":"Bernardo was very touchy, and took any slight as an affront to his honor"}]},{"Word":"aggrandize","Definitions":[{"Partofspeech":"verb","Meaning":"to increase or make greater","Sentence":"Joseph always dropped the names of the famous people his father knew as a way to aggrandize his personal stature."}]}]