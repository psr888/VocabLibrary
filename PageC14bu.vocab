[{"Word":"catalog","Definitions":[{"Partofspeech":"verb","Meaning":"to list, enter into a list","Sentence":"The judge cataloged the victim’s injuries before calculating how much money he would award."},{"Partofspeech":"noun","Meaning":"a list or collection","Sentence":"We received a catalog from J. Crew that displayed all of their new items."}]},{"Word":"catalyze","Definitions":[{"Partofspeech":"verb","Meaning":" to charge, inspire","Sentence":"The president’s speech catalyzed the nation and resuscitated the economy."}]},{"Word":"caucus","Definitions":[{"Partofspeech":"noun","Meaning":"a meeting usually held by people working toward the same goal ","Sentence":"The ironworkers held a caucus to determine how much of a pay increase they would request."}]},{"Word":"caustic","Definitions":[{"Partofspeech":"adjective","Meaning":"bitter, biting, acidic","Sentence":"The politicians exchanged caustic insults for over an hour during the debate."}]},{"Word":"cavort","Definitions":[{"Partofspeech":"verb","Meaning":" to leap about, behave boisterously","Sentence":"The adults ate their dinners on the patio, while the children cavorted around the pool."}]},{"Word":"censure","Definitions":[{"Partofspeech":"noun","Meaning":" harsh criticism ","Sentence":"The frustrated teenager could not put up with anymore of her critical mother’s censure."},{"Partofspeech":"verb","Meaning":"to rebuke formally","Sentence":"The principal censured the head of the English Department for forcing students to learn esoteric vocabulary."}]},{"Word":"cerebral","Definitions":[{"Partofspeech":"adjective","Meaning":"related to the intellect","Sentence":"The books we read in this class are too cerebral— they don’t engage my emotions at all."}]},{"Word":"chaos","Definitions":[{"Partofspeech":"noun","Meaning":"absolute disorder","Sentence":"Mr. Thornton’s sudden departure for the lavatory plunged his classroom into chaos."}]},{"Word":"chastise","Definitions":[{"Partofspeech":"verb","Meaning":"to criticize severely","Sentence":"After being chastised by her peers for mimicking Britney Spears, Miranda dyed her hair black and affected a Gothic style."}]},{"Word":"cherish","Definitions":[{"Partofspeech":"verb","Meaning":"to feel or show affection toward something","Sentence":"She continued to cherish her red plaid trousers, even though they had gone out of style and no longer fit her."}]},{"Word":"chide","Definitions":[{"Partofspeech":"verb","Meaning":"to voice disapproval","Sentence":"Lucy chided Russell for his vulgar habits and sloppy appearance."}]},{"Word":"choreography","Definitions":[{"Partofspeech":"noun","Meaning":"the arrangement of dances ","Sentence":"The plot of the musical was banal, but the choreography was stunning."}]},{"Word":"chronicle","Definitions":[{"Partofspeech":"noun","Meaning":"a written history","Sentence":"The library featured the newly updated chronicle of World War II."},{"Partofspeech":"verb","Meaning":"to write a history","Sentence":"Albert’s diary chronicled the day-to-day growth of his obsession with Cynthia."}]},{"Word":"chronological ","Definitions":[{"Partofspeech":"adjective","Meaning":"arranged in order of time ","Sentence":"Lionel carefully arranged the snapshots of his former girlfriends in chronological order, and then set fire to them."}]}]