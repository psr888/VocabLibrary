[{"Word":"aggregate","Definitions":[{"Partofspeech":"noun","Meaning":"a whole or total","Sentence":"The three branches of the U.S. Government form an aggregate much more powerful than its individual parts."}]},{"Word":"aggrieved","Definitions":[{"Partofspeech":"adjective","Meaning":"distressed, wronged, injured","Sentence":"The foreman mercilessly overworked his aggrieved employees"}]},{"Word":"agile","Definitions":[{"Partofspeech":"adjective","Meaning":"quick, nimble","Sentence":"The dogs were too slow to catch the agile rabbit."}]},{"Word":"agnostic","Definitions":[{"Partofspeech":"adjective","Meaning":"believing that the existence of God cannot be proven or disproven","Sentence":"Joey’s parents are very religious, but he is agnostic."}]},{"Word":"agriculture","Definitions":[{"Partofspeech":"noun","Meaning":"farming","Sentence":"It was a huge step in the progress of civilization when tribes left hunting and gathering and began to develop more sustainable methods of obtaining food, such as agriculture."}]},{"Word":"aisle","Definitions":[{"Partofspeech":"noun","Meaning":"a passageway between rows of seats","Sentence":"Once we got inside the stadium we walked down the aisle to our seats."}]},{"Word":"alacrity","Definitions":[{"Partofspeech":"noun","Meaning":"eagerness, speed","Sentence":"For some reason, Chuck loved to help his mother whenever he could, so when his mother asked him to set the table he did so with alacrity."}]},{"Word":"alias","Definitions":[{"Partofspeech":"noun","Meaning":"a false name or identity","Sentence":"He snuck past the guards by using an alias and fake ID."}]},{"Word":"allay","Definitions":[{"Partofspeech":"verb","Meaning":"to soothe, ease","Sentence":"The chairman of the Federal Reserve gave a speech to try to allay investors’ fears about an economic downturn."}]},{"Word":"allege ","Definitions":[{"Partofspeech":"verb","Meaning":"to assert, usually without proof","Sentence":"The policeman had alleged that Marshall committed the crime, but after the investigation turned up no evidence, Marshall was set free."}]},{"Word":"alleviate","Definitions":[{"Partofspeech":"verb","Meaning":"to relieve, make more bearable","Sentence":"This drug will alleviate the symptoms of the terrible disease, but only for a while."}]},{"Word":"allocate ","Definitions":[{"Partofspeech":"verb","Meaning":"to distribute, set aside","Sentence":"The Mayor allocated 30 percent of the funds for improving the town’s schools."}]},{"Word":"aloof","Definitions":[{"Partofspeech":"adjective","Meaning":"reserved, distant","Sentence":"The scientist could sometimes seem aloof, as if he didn’t care about his friends or family, but really he was just thinking about quantum mechanics. "}]},{"Word":"altercation","Definitions":[{"Partofspeech":"noun","Meaning":"a dispute, fight ","Sentence":"Jason and Lionel blamed one another for the car accident, leading to an altercation."}]}]