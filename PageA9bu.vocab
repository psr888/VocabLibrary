[{"Word":"arcane","Definitions":[{"Partofspeech":"adjective","Meaning":"obscure, secret, known only by a few","Sentence":"The professor is an expert in arcane Lithuanian literature."}]},{"Word":"archaic","Definitions":[{"Partofspeech":"adjective","Meaning":"of or relating to an earlier period in time, outdated","Sentence":"In a few select regions of Western Mongolian, an archaic Chinese dialect is still spoken."}]},{"Word":"archetypal","Definitions":[{"Partofspeech":"adjective","Meaning":"the most representative or typical example of something","Sentence":"Some believe George Washington, with his flowing white hair and commanding stature, was the archetypal politician."}]},{"Word":"ardor","Definitions":[{"Partofspeech":"noun","Meaning":"extreme vigor, energy, enthusiasm ","Sentence":"The soldiers conveyed their ardor with impassioned battle cries."}]},{"Word":"arid","Definitions":[{"Partofspeech":"adjective","Meaning":"excessively dry","Sentence":"Little other than palm trees and cacti grow successfully in arid environments."}]},{"Word":"arrogate","Definitions":[{"Partofspeech":"verb","Meaning":"to take without justification","Sentence":"The king arrogated the right to order executions to himself exclusively."}]},{"Word":"artifact ","Definitions":[{"Partofspeech":"noun","Meaning":"a remaining piece from an extinct culture or place","Sentence":"The scientists spent all day searching the cave for artifacts from the ancient Mayan civilization."}]},{"Word":"artisan","Definitions":[{"Partofspeech":"noun","Meaning":"a craftsman","Sentence":"The artisan uses wood to make walking sticks."}]},{"Word":"ascertain","Definitions":[{"Partofspeech":"verb","Meaning":"to perceive, learn","Sentence":"With a bit of research, the student ascertained that some plants can live for weeks without water."}]},{"Word":"ascetic ","Definitions":[{"Partofspeech":"adjective","Meaning":"practicing restraint as a means of self-discipline, usually religious","Sentence":"The priest lives an ascetic life devoid of television, savory foods, and other pleasures."}]},{"Word":"ascribe","Definitions":[{"Partofspeech":"verb","Meaning":"to assign, credit, attribute to","Sentence":"Some ascribe the invention of fireworks and dynamite to the Chinese."}]},{"Word":"aspersion","Definitions":[{"Partofspeech":"noun","Meaning":"a curse, expression of ill-will","Sentence":"The rival politicians repeatedly cast aspersions on each others’ integrity."}]},{"Word":"aspire","Definitions":[{"Partofspeech":"verb","Meaning":"to long for, aim toward","Sentence":"The young poet aspires to publish a book of verse someday."}]},{"Word":"assail ","Definitions":[{"Partofspeech":"verb","Meaning":"to attack","Sentence":"At dawn, the war planes assailed the boats in the harbor."}]},{"Word":"assess","Definitions":[{"Partofspeech":"verb","Meaning":" to evaluate","Sentence":"A crew arrived to assess the damage after the crash."}]},{"Word":"assiduous ","Definitions":[{"Partofspeech":"adj.","Meaning":"hard-working, diligent","Sentence":"The construction workers erected the skyscraper during two years of assiduous labor."}]},{"Word":"assuage","Definitions":[{"Partofspeech":"verb","Meaning":"to ease, pacify","Sentence":"The mother held the baby to assuage its fears."}]}]