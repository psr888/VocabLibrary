[{"Word":"amalgamate","Definitions":[{"Partofspeech":"verb","Meaning":"to bring together, unite","Sentence":"Because of his great charisma, the presidential candidate was able to amalgamate all democrats and republicans under his banner."}]},{"Word":"ambiguous","Definitions":[{"Partofspeech":"adjective","Meaning":"uncertain, variably interpretable","Sentence":"Some people think Caesar married Cleopatra for her power, others believe he was charmed by her beauty. His actual reasons are ambiguous. "}]},{"Word":"ambivalent ","Definitions":[{"Partofspeech":"adjective","Meaning":"having opposing feelings ","Sentence":"My feelings about Calvin are ambivalent because on one hand he is a loyal friend, but on the other, he is a cruel and vicious thief."}]},{"Word":"ameliorate","Definitions":[{"Partofspeech":"verb","Meaning":"to improve ","Sentence":"The tense situation was ameliorated when Sam proposed a solution everyone could agree upon."}]},{"Word":"amenable ","Definitions":[{"Partofspeech":"adjective","Meaning":"willing, compliant","Sentence":"Our father was amenable when we asked him to drive us to the farm so we could go apple picking."}]},{"Word":"amenity","Definitions":[{"Partofspeech":"noun","Meaning":"an item that increases comfort ","Sentence":"Bill Gates’s house is stocked with so many amenities, he never has to do anything for himself."}]},{"Word":"amiable","Definitions":[{"Partofspeech":"adjective","Meaning":"friendly","Sentence":"An amiable fellow, Harry got along with just about everyone."}]},{"Word":"amicable","Definitions":[{"Partofspeech":"adjective","Meaning":"friendly","Sentence":"Claudia and Jimmy got divorced, but amicably and without hard feelings."}]},{"Word":"amorous","Definitions":[{"Partofspeech":"adjective","Meaning":"showing love, particularly sexual","Sentence":"Whenever Albert saw Mariah wear her slinky red dress, he began to feel quite amorous."}]},{"Word":"amorphous ","Definitions":[{"Partofspeech":"adjective","Meaning":"without definite shape or type ","Sentence":"The effort was doomed from the start, because the reasons behind it were so amorphous and hard to pin down."}]},{"Word":"anachronistic","Definitions":[{"Partofspeech":"adjective","Meaning":"being out of correct chronological order","Sentence":"In this book you’re writing, you say that the Pyramids were built after the Titanic sank, which is anachronistic."}]},{"Word":"analgesic ","Definitions":[{"Partofspeech":"noun","Meaning":"something that reduces pain","Sentence":"Put this analgesic on the wound so that the poor man at least feels a little better."}]},{"Word":"analogous ","Definitions":[{"Partofspeech":"adjective","Meaning":"similar to, so that an analogy can be drawn ","Sentence":"Though they are unrelated genetically, the bone structure of whales and fish is quite analogous."}]},{"Word":"anarchist ","Definitions":[{"Partofspeech":"noun","Meaning":"one who wants to eliminate all government","Sentence":"An anarchist, Carmine wanted to dissolve every government everywhere."}]},{"Word":"anathema","Definitions":[{"Partofspeech":"noun","Meaning":"a cursed, detested person","Sentence":"I never want to see that murderer. He is an anathema to me."}]}]