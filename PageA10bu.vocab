[{"Word":"astute","Definitions":[{"Partofspeech":"adjective","Meaning":"very clever, crafty","Sentence":"Much of Roger’s success in politics results from his ability to provide astute answers to reporters’ questions."}]},{"Word":"asylum ","Definitions":[{"Partofspeech":"noun","Meaning":"a place of refuge, protection, a sanctuary","Sentence":"For Thoreau, the forest served as an asylum from the pressures of urban life."}]},{"Word":"atone","Definitions":[{"Partofspeech":"verb","Meaning":"to repent, make amends","Sentence":"The man atoned for forgetting his wife’s birthday by buying her five dozen roses."}]},{"Word":"atrophy","Definitions":[{"Partofspeech":"verb","Meaning":"to wither away, decay","Sentence":"If muscles do not receive enough blood, they will soon atrophy and die."}]},{"Word":"attain","Definitions":[{"Partofspeech":"verb","Meaning":" to achieve, arrive at","Sentence":"The athletes strived to attain their best times in competition."}]},{"Word":"attribute","Definitions":[{"Partofspeech":"verb","Meaning":"to credit, assign","Sentence":"He attributes all of his success to his mother’s undying encouragement."}]},{"Word":"atypical","Definitions":[{"Partofspeech":"adjective","Meaning":"not typical, unusual","Sentence":"Screaming and crying is atypical adult behavior."}]},{"Word":"audacious","Definitions":[{"Partofspeech":"adjective","Meaning":"excessively bold","Sentence":"The security guard was shocked by the fan’s audacious attempt to offer him a bribe."}]},{"Word":"audible","Definitions":[{"Partofspeech":"adjective","Meaning":"able to be heard","Sentence":"The missing person’s shouts were unfortunately not audible."}]},{"Word":"augment","Definitions":[{"Partofspeech":"verb","Meaning":"to add to, expand ","Sentence":"The eager student seeks to augment his knowledge of French vocabulary by reading French literature."}]},{"Word":"auspicious","Definitions":[{"Partofspeech":"adjective","Meaning":"favorable, indicative of good things","Sentence":"The tennis player considered the sunny forecast an auspicious sign that she would win her match."}]},{"Word":"austere","Definitions":[{"Partofspeech":"adjective","Meaning":"very bare, bleak ","Sentence":"The austere furniture inside the abandoned house made the place feel haunted."}]},{"Word":"avarice","Definitions":[{"Partofspeech":"noun","Meaning":"excessive greed","Sentence":"The banker’s avarice led him to amass a tremendous personal fortune."}]},{"Word":"avenge","Definitions":[{"Partofspeech":"verb ","Meaning":"to seek revenge","Sentence":"The victims will take justice into their own hands and strive to avenge themselves against the men who robbed them."}]},{"Word":"aversion","Definitions":[{"Partofspeech":"noun","Meaning":"a particular dislike for something","Sentence":"Because he’s from Hawaii, Ben has an aversion to autumn, winter, and cold climates in general"}]}]