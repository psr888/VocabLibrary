[{"Word":"bilk","Definitions":[{"Partofspeech":"verb","Meaning":"cheat, defraud","Sentence":"The lawyer discovered that this firm had bilked several clients out of thousands of dollars."}]},{"Word":"blandish","Definitions":[{"Partofspeech":"verb","Meaning":"to coax by using flattery ","Sentence":"Rachel’s assistant tried to blandish her into accepting the deal."}]},{"Word":"blemish","Definitions":[{"Partofspeech":"noun","Meaning":"an imperfection, flaw","Sentence":"The dealer agreed to lower the price because of the many blemishes on the surface of the wooden furniture."}]},{"Word":"blight ","Definitions":[{"Partofspeech":"noun","Meaning":"a plague, disease","Sentence":"The potato blight destroyed the harvest and bankrupted many families."},{"Partofspeech":"noun","Meaning":"something that destroys hope","Sentence":"His bad morale is a blight upon this entire operation."}]},{"Word":"boisterous","Definitions":[{"Partofspeech":"adjective","Meaning":"loud and full of energy ","Sentence":"The candidate won the vote after giving several boisterous speeches on television."}]},{"Word":"bombastic","Definitions":[{"Partofspeech":"adjective","Meaning":"excessively confident, pompous","Sentence":"The singer’s bombastic performance disgusted the crowd."}]},{"Word":"boon","Definitions":[{"Partofspeech":"noun","Meaning":"a gift or blessing","Sentence":"The good weather has been a boon for many businesses located near the beach."}]},{"Word":"bourgeois","Definitions":[{"Partofspeech":"noun","Meaning":"a middle-class person, capitalist","Sentence":"Many businessmen receive criticism for their bourgeois approach to life."}]},{"Word":"brazen","Definitions":[{"Partofspeech":"adjective","Meaning":"excessively bold, brash ","Sentence":"Critics condemned the novelist’s brazen attempt to plagiarize Hemingway’s story."}]},{"Word":"brusque","Definitions":[{"Partofspeech":"adjective","Meaning":" short, abrupt, dismissive","Sentence":"The captain’s brusque manner offended the passengers."}]},{"Word":"buffet","Definitions":[{"Partofspeech":"verb","Meaning":"to strike with force","Sentence":"The strong winds buffeted the ships, threatening to capsize them."},{"Partofspeech":"noun","Meaning":"an arrangement of food set out on a table","Sentence":"Rather than sitting around a table, the guests took food from our buffet and ate standing up."}]},{"Word":"burnish","Definitions":[{"Partofspeech":"verb","Meaning":"to support, hold up","Sentence":"The column buttresses the roof above the statue"},{"Partofspeech":"noun","Meaning":"something that offers support","Sentence":"The buttress supports the roof above the statues."}]},{"Word":"cacophony","Definitions":[{"Partofspeech":"noun","Meaning":"tremendous noise, disharmonious sound","Sentence":"The elementary school orchestra created a cacophony at the recital."}]}]