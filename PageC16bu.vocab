[{"Word":"coalesce","Definitions":[{"Partofspeech":"verb","Meaning":" to fuse into a whole","Sentence":"Gordon’s ensemble of thrift-shop garments coalesced into a surprisingly handsome outfit."}]},{"Word":"cobbler","Definitions":[{"Partofspeech":"noun","Meaning":"a person who makes or repairs shoes","Sentence":"I had my neighborhood cobbler replace my worn-out leather soles with new ones."}]},{"Word":"coerce ","Definitions":[{"Partofspeech":"verb","Meaning":"to make somebody do something by force or threat","Sentence":"The court decided that Vanilla Ice did not have to honor the contract because he had been coerced into signing it."}]},{"Word":"cogent","Definitions":[{"Partofspeech":"adjective","Meaning":"intellectually convincing","Sentence":"Irene’s arguments in favor of abstinence were so cogent that I could not resist them."}]},{"Word":"cognizant","Definitions":[{"Partofspeech":"adjective","Meaning":"aware, mindful","Sentence":"Jake avoided speaking to women in bars because he was cognizant of the fact that drinking impairs his judgment."}]},{"Word":"coherent","Definitions":[{"Partofspeech":"adjective","Meaning":"logically consistent, intelligible","Sentence":"Renee could not figure out what Monroe had seen because he was too distraught to deliver a coherent statement."}]},{"Word":"collateral","Definitions":[{"Partofspeech":"adjective","Meaning":"secondary","Sentence":"Divorcing my wife had the collateral effect of making me poor, as she was the only one of us with a job or money."},{"Partofspeech":"noun","Meaning":"security for a debt ","Sentence":"Jacob left his watch as collateral for the $500 loan."}]},{"Word":"colloquial","Definitions":[{"Partofspeech":"adjective","Meaning":"characteristic of informal conversation","Sentence":"Adam’s essay on sexual response in primates was marked down because it contained too many colloquial expressions."}]},{"Word":"collusion","Definitions":[{"Partofspeech":"noun","Meaning":"secret agreement, conspiracy","Sentence":"The three law students worked in collusion to steal the final exam."}]},{"Word":"colossus ","Definitions":[{"Partofspeech":"noun","Meaning":"a gigantic statue or thing ","Sentence":"For 56 years, the ancient city of Rhodes featured a colossus standing astride its harbor."}]},{"Word":"combustion ","Definitions":[{"Partofspeech":"noun","Meaning":" the act or process of burning","Sentence":"The unexpected combustion of the prosecution’s evidence forced the judge to dismiss the case against Ramirez."}]},{"Word":"commendation","Definitions":[{"Partofspeech":"noun","Meaning":"a notice of approval or recognition","Sentence":"Jared received a commendation from Linda, his supervisor, for his stellar performance."}]},{"Word":"commensurate","Definitions":[{"Partofspeech":"adjective","Meaning":"corresponding in size or amount ","Sentence":"Ahab selected a very long roll and proceeded to prepare a tuna salad sandwich commensurate with his enormous appetite."}]},{"Word":"commodious ","Definitions":[{"Partofspeech":"adjective","Meaning":"roomy","Sentence":"Holden invited the three women to join him in the back seat of the taxicab, assuring them that the car was quite commodious."}]}]