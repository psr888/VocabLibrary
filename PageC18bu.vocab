[{"Word":"concise","Definitions":[{"Partofspeech":"adj","Meaning":" brief and direct in expression","Sentence":"Gordon did not like to waste time, and his instructions to Brenda were nothing if not concise."}]},{"Word":"concoct","Definitions":[{"Partofspeech":"verb","Meaning":"to fabricate, make up","Sentence":"She concocted the most ridiculous story to explain her absence."}]},{"Word":"concomitant","Definitions":[{"Partofspeech":"adj","Meaning":" accompanying in a subordinate fashion","Sentence":"His dislike of hard work carried with it a concomitant lack of funds."}]},{"Word":"concord","Definitions":[{"Partofspeech":"noun","Meaning":"harmonious agreement","Sentence":"Julie and Harold began the evening with a disagreement, but ended it in a state of perfect concord."}]},{"Word":"condolence","Definitions":[{"Partofspeech":"noun","Meaning":"an expression of sympathy in sorrow ","Sentence":"Brian lamely offered his condolences on the loss of his sister’s roommate’s cat."}]},{"Word":"condone","Definitions":[{"Partofspeech":"verb","Meaning":" to pardon, deliberately overlook ","Sentence":"He refused to condone his brother’s crime."}]},{"Word":"conduit","Definitions":[{"Partofspeech":"noun","Meaning":"a pipe or channel through which something passes ","Sentence":"The water flowed through the conduit into the container."}]},{"Word":"confection","Definitions":[{"Partofspeech":"noun","Meaning":"a sweet, fancy food","Sentence":"We went to the mall food court and purchased a delicious confection."}]},{"Word":"confidant ","Definitions":[{"Partofspeech":"noun","Meaning":"a person entrusted with secrets","Sentence":"Shortly after we met, she became my chief confidant."}]},{"Word":"conflagration ","Definitions":[{"Partofspeech":"noun","Meaning":" great fire","Sentence":"The conflagration consumed the entire building."}]},{"Word":"confluence","Definitions":[{"Partofspeech":"noun","Meaning":"a gathering together","Sentence":"A confluence of different factors made tonight the perfect night."}]},{"Word":"conformist","Definitions":[{"Partofspeech":"noun","Meaning":"one who behaves the same as others","Sentence":"Julian was such a conformist that he had to wait and see if his friends would do something before he would commit."}]},{"Word":"confound","Definitions":[{"Partofspeech":"verb","Meaning":"to frustrate, confuse","Sentence":"MacGuyver confounded the policemen pursuing him by covering his tracks."}]},{"Word":"congeal","Definitions":[{"Partofspeech":"verb","Meaning":"to thicken into a solid ","Sentence":"The sauce had congealed into a thick paste."}]},{"Word":"congenial","Definitions":[{"Partofspeech":"adj","Meaning":"pleasantly agreeable","Sentence":"His congenial manner made him popular wherever he went."}]},{"Word":"congregation","Definitions":[{"Partofspeech":"noun","Meaning":"a gathering of people, especially for religious services ","Sentence":"The priest told the congregation that he would be retiring."}]},{"Word":"congruity","Definitions":[{"Partofspeech":"noun","Meaning":"the quality of being in agreement ","Sentence":"Bill and Veronica achieved a perfect congruity of opinion."}]}]