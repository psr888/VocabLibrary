[{"Word":"abase","Definitions":[{"Partofspeech":"verb","Meaning":"to humiliate, degrade","Sentence":"After being overthrown and abased, the deposed leader offered to bow down to his conqueror."}]},{"Word":"abate","Definitions":[{"Partofspeech":"verb","Meaning":"to reduce, lessen","Sentence":"The rain poured down for a while, then abated."}]},{"Word":"abdicate","Definitions":[{"Partofspeech":"verb","Meaning":" to give up a position, usually one of leadership","Sentence":"When he realized that the revolutionaries would surely win, the king abdicated his throne."}]},{"Word":"abduct","Definitions":[{"Partofspeech":"verb","Meaning":"to kidnap, take by force","Sentence":"The evildoers abducted the fairy princess from her happy home."}]},{"Word":"aberration","Definitions":[{"Partofspeech":"noun","Meaning":"something that differs from the norm ","Sentence":"In 1918, the Boston Red Sox won the World Series, but the success turned out to be an aberration, and the Red Sox have not won a World Series since."}]},{"Word":"abet","Definitions":[{"Partofspeech":"verb","Meaning":"to aid, help, encourage","Sentence":"The spy succeeded only because he had a friend on the inside to abet him."}]}]