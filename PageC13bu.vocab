[{"Word":"cadence","Definitions":[{"Partofspeech":"noun","Meaning":"a rhythm, progression of sound","Sentence":"The pianist used the foot pedal to emphasize the cadence of the sonata."}]},{"Word":"cajole ","Definitions":[{"Partofspeech":"verb","Meaning":" to urge, coax ","Sentence":"Fred’s buddies cajoled him into attending the bachelor party."}]},{"Word":"calamity","Definitions":[{"Partofspeech":"noun","Meaning":"an event with disastrous consequences","Sentence":"The earthquake in San Francisco was a calamity worse than any other natural disaster in history."}]},{"Word":"calibrate","Definitions":[{"Partofspeech":"verb","Meaning":"to set, standardize","Sentence":"The mechanic calibrated the car’s transmission to make the motor run most efficiently."}]},{"Word":"callous","Definitions":[{"Partofspeech":"adjective","Meaning":"harsh, cold, unfeeling","Sentence":"The murderer’s callous lack of remorse shocked the jury."}]},{"Word":"calumny ","Definitions":[{"Partofspeech":"noun","Meaning":"an attempt to spoil someone else’s reputation by spreading lies ","Sentence":"The local official’s calumny ended up ruining his opponent’s prospect of winning the election."}]},{"Word":"camaraderie","Definitions":[{"Partofspeech":"noun","Meaning":"brotherhood, jovial unity","Sentence":"Camaraderie among employees usually leads to success in business."}]},{"Word":"candor ","Definitions":[{"Partofspeech":"noun","Meaning":"honesty, frankness","Sentence":"We were surprised by the candor of the mayor’s speech because he is usually rather evasive."}]},{"Word":"canny","Definitions":[{"Partofspeech":"adjective","Meaning":"shrewd, careful","Sentence":"The canny runner hung at the back of the pack through much of the race to watch the other runners, and then sprinted past them at the end."}]},{"Word":"canvas","Definitions":[{"Partofspeech":"noun","Meaning":"a piece of cloth on which an artist paints","Sentence":"Picasso liked to work on canvas rather than on bare cement."},{"Partofspeech":"verb","Meaning":"to cover, inspect","Sentence":"We canvassed the neighborhood looking for clues."}]},{"Word":"capacious","Definitions":[{"Partofspeech":"adjective","Meaning":"very spacious","Sentence":"The workers delighted in their new capacious office space."}]},{"Word":"capitulate","Definitions":[{"Partofspeech":"verb","Meaning":"to surrender","Sentence":"The army finally capitulated after fighting a long costly battle."}]},{"Word":"capricious","Definitions":[{"Partofspeech":"adjective","Meaning":"subject to whim, fickle","Sentence":"The young girl’s capricious tendencies made it difficult for her to focus on achieving her goals."}]},{"Word":"captivate","Definitions":[{"Partofspeech":"verb","Meaning":"to get the attention of, hold ","Sentence":""}]},{"Word":"carouse","Definitions":[{"Partofspeech":"verb","Meaning":"to party, celebrate","Sentence":"We caroused all night after getting married."}]},{"Word":"carp ","Definitions":[{"Partofspeech":"verb","Meaning":"to annoy, pester ","Sentence":"The husband divorced his wife after listening to her carping voice for decades."}]}]