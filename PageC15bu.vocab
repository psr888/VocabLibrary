[{"Word":"circuitous","Definitions":[{"Partofspeech":"adjective","Meaning":"roundabout","Sentence":"The bus’s circuitous route took us through numerous outlying suburbs."}]},{"Word":"circumlocution","Definitions":[{"Partofspeech":"noun","Meaning":"indirect and wordy language ","Sentence":"The professor’s habit of speaking in circumlocutions made it difficult to follow his lectures."}]},{"Word":"circumscribed","Definitions":[{"Partofspeech":"adjective","Meaning":" marked off, bounded","Sentence":"The children were permitted to play tag only within a carefully circumscribed area of the lawn."}]},{"Word":"circumspect","Definitions":[{"Partofspeech":"adjective","Meaning":"cautious","Sentence":"Though I promised Rachel’s father I would bring her home promptly by midnight, it would have been more circumspect not to have specified a time."}]},{"Word":"circumvent","Definitions":[{"Partofspeech":"verb","Meaning":"to get around","Sentence":"The school’s dress code forbidding navel-baring jeans was circumvented by the determined students, who were careful to cover up with long coats when administrators were nearby."}]},{"Word":"clairvoyant ","Definitions":[{"Partofspeech":"adjective","Meaning":"able to perceive things that normal people cannot ","Sentence":"Zelda’s uncanny ability to detect my lies was nothing short of clairvoyant."}]},{"Word":"clamor","Definitions":[{"Partofspeech":"noun","Meaning":"loud noise","Sentence":"Each morning the birds outside my window make such a clamor that they wake me up."},{"Partofspeech":"verb","Meaning":"to loudly insist","Sentence":"Neville’s fans clamored for him to appear on stage, but he had passed out on the floor of his dressing room."}]},{"Word":"clandestine","Definitions":[{"Partofspeech":"adjective","Meaning":"secret","Sentence":"Announcing to her boyfriend that she was going to the gym, Sophie actually went to meet Joseph for a clandestine liaison."}]},{"Word":"cleave","Definitions":[{"Partofspeech":"verb","Meaning":"to divide into parts","Sentence":"Following the scandalous disgrace of their leader, the entire political party cleaved into warring factions."},{"Partofspeech":"verb","Meaning":"to stick together firmly ","Sentence":"After resolving their marital problems, Junior and Rosa cleaved to one another all the more tightly."}]},{"Word":"clemency","Definitions":[{"Partofspeech":"noun","Meaning":"mercy","Sentence":"After he forgot their anniversary, Martin could only beg Maria for clemency."}]},{"Word":"clergy","Definitions":[{"Partofspeech":"noun","Meaning":"members of Christian holy orders ","Sentence":"Though the villagers viewed the church rectory as quaint and charming, the clergy who lived there regarded it as a mildewy and dusty place that aggravated their allergies."}]},{"Word":"cloying","Definitions":[{"Partofspeech":"adjective","Meaning":"sickeningly sweet ","Sentence":"Though Ronald was physically attractive, Maud found his constant compliments and solicitous remarks cloying."}]},{"Word":"coagulate","Definitions":[{"Partofspeech":"verb","Meaning":"to thicken, clot","Sentence":"The top layer of the pudding had coagulated into a thick skin."}]}]