[{"Word":"anecdote","Definitions":[{"Partofspeech":"noun","Meaning":"a short, humorous account","Sentence":"After dinner, Marlon told an anecdote about the time he got his nose stuck in a toaster."}]},{"Word":"anesthesia","Definitions":[{"Partofspeech":"noun","Meaning":"loss of sensation ","Sentence":"When the nerves in his spine were damaged, Mr. Hollins suffered anesthesia in his legs."}]},{"Word":"anguish","Definitions":[{"Partofspeech":"noun","Meaning":"extreme sadness, torment","Sentence":"Angelos suffered terrible anguish when he learned that Buffy had died while combating a strange mystical force of evil."}]},{"Word":"animated","Definitions":[{"Partofspeech":"adjective","Meaning":"lively","Sentence":"When he begins to talk about drama, which is his true passion, he becomes very animated."}]},{"Word":"annex","Definitions":[{"Partofspeech":"verb","Meaning":"to incorporate territory or space","Sentence":"After defeating them in battle, the Russians annexed Poland."}]},{"Word":"annul","Definitions":[{"Partofspeech":"verb","Meaning":"to make void or invalid","Sentence":"After seeing its unforeseen and catastrophic effects, Congress sought to annul the law."}]},{"Word":"anomaly","Definitions":[{"Partofspeech":"noun","Meaning":"something that does not fit into the normal order","Sentence":"\"That rip in the space time continuum is certainly a spatial anomaly,” said Spock to Captain Kirk"}]},{"Word":"anonymous","Definitions":[{"Partofspeech":"adjective","Meaning":"being unknown, unrecognized","Sentence":"Mary received a love poem from an anonymous admirer"}]},{"Word":"antagonism","Definitions":[{"Partofspeech":"noun","Meaning":"hostility","Sentence":"Superman and Bizarro Superman shared a mutual antagonism, and often fought."}]},{"Word":"antecedent","Definitions":[{"Partofspeech":"noun","Meaning":"something that came before","Sentence":"The great tradition of Western culture had its antecedent in the culture of Ancient Greece."}]},{"Word":"antediluvian","Definitions":[{"Partofspeech":"adjective","Meaning":"ancient","Sentence":"The antediluvian man still believed that Eisenhower was president of the United States and that hot dogs cost a nickel."}]},{"Word":"anthology","Definitions":[{"Partofspeech":"noun","Meaning":"a selected collection of writings, songs, etc.","Sentence":"The new anthology of Bob Dylan songs contains all his greatest hits and a few songs that you might never have heard before."}]},{"Word":"antipathy","Definitions":[{"Partofspeech":"noun","Meaning":"a strong dislike, repugnance","Sentence":"I know you love me, but because you are a liar and a thief, I feel nothing but antipathy for you."}]},{"Word":"antiquated","Definitions":[{"Partofspeech":"adjective","Meaning":"old, out of date","Sentence":"That antiquated car has none of the features, like power windows and steering, that make modern cars so great."}]},{"Word":"antiseptic","Definitions":[{"Partofspeech":"adjective","Meaning":"clean, sterile","Sentence":"The antiseptic hospital was very bare, but its cleanliness helped to keep patients healthy."}]},{"Word":"antithesis","Definitions":[{"Partofspeech":"noun","Meaning":"the absolute opposite","Sentence":"Your values, which hold war and violence in the highest esteem, are the antithesis of my pacifist beliefs."}]},{"Word":"anxiety","Definitions":[{"Partofspeech":"noun","Meaning":"intense uneasiness","Sentence":"When he heard about the car crash, he felt anxiety because he knew that his girlfriend had been driving on the road where the accident occurred. "}]},{"Word":"apathetic","Definitions":[{"Partofspeech":"adjective","Meaning":"lacking concern, emotion","Sentence":"Uninterested in politics, Bruno was apathetic about whether he lived under a capitalist or communist regime."}]},{"Word":"apocryphal ","Definitions":[{"Partofspeech":"adjective","Meaning":" fictitious, false, wrong ","Sentence":"Because I am standing before you, it seems obvious that the stories circulating about my demise were apocryphal."}]},{"Word":"appalling","Definitions":[{"Partofspeech":"adjective","Meaning":"inspiring shock, horror, disgust","Sentence":"The judge found the murderer’s crimes and lack of remorse appalling."}]},{"Word":"appease","Definitions":[{"Partofspeech":"verb","Meaning":"to calm, satisfy","Sentence":"When the child cries, the mother gives him candy to appease him."}]},{"Word":"appraise","Definitions":[{"Partofspeech":"verb","Meaning":"to assess the worth or value of","Sentence":"A realtor will come over tonight to appraise our house."}]},{"Word":"apprehend","Definitions":[{"Partofspeech":"verb","Meaning":"to seize, arrest","Sentence":"The criminal was apprehended at the scene."}]},{"Word":"approbation","Definitions":[{"Partofspeech":"noun","Meaning":"praise","Sentence":"The crowd welcomed the heroes with approbation."}]},{"Word":"appropriate","Definitions":[{"Partofspeech":"verb","Meaning":"to take, make use of","Sentence":"The government appropriated the farmer’s land without justification."}]},{"Word":"aquatic","Definitions":[{"Partofspeech":"adjective","Meaning":"relating to water ","Sentence":"The marine biologist studies starfish and other aquatic creatures."}]},{"Word":"arable","Definitions":[{"Partofspeech":"adjective","Meaning":"suitable for growing crops","Sentence":"The farmer purchased a plot of arable land on which he will grow corn and sprouts."}]},{"Word":"arbiter","Definitions":[{"Partofspeech":"noun","Meaning":"one who can resolve a dispute, make a decision","Sentence":"The divorce court judge will serve as the arbiter between the estranged husband and wife."}]},{"Word":"arbitrary","Definitions":[{"Partofspeech":"adjective","Meaning":"based on factors that appear random","Sentence":"The boy’s decision to choose one college over another seems arbitrary."}]},{"Word":"arbitration","Definitions":[{"Partofspeech":"noun","Meaning":" the process or act of resolving a dispute ","Sentence":"The employee sought official arbitration when he could not resolve a disagreement with his supervisor."}]},{"Word":"arboreal","Definitions":[{"Partofspeech":"adjective","Meaning":"of or relating to trees ","Sentence":"Leaves, roots, and bark are a few arboreal traits."}]}]