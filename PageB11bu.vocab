[{"Word":"balk","Definitions":[{"Partofspeech":"verb","Meaning":"to stop, block abruptly","Sentence":"Edna’s boss balked at her request for another raise."}]},{"Word":"ballad","Definitions":[{"Partofspeech":"noun","Meaning":"a love song","Sentence":"Greta’s boyfriend played her a ballad on the guitar during their walk through the dark woods."}]},{"Word":"banal","Definitions":[{"Partofspeech":"adjective","Meaning":"dull,commonplace","Sentence":"The client rejected our proposal because they found our presentation banal and unimpressive."}]},{"Word":"bane","Definitions":[{"Partofspeech":"noun","Meaning":" a burden","Sentence":"Advanced physics is the bane of many students’ academic lives."}]},{"Word":"bard","Definitions":[{"Partofspeech":"noun","Meaning":" a poet, often a singer as well","Sentence":"Shakespeare is often considered the greatest bard in the history of the English language."}]},{"Word":"bashful ","Definitions":[{"Partofspeech":"adjective","Meaning":"shy, excessively timid","Sentence":"Frankie’s mother told him not to be bashful when he refused to attend the birthday party."}]},{"Word":"battery","Definitions":[{"Partofspeech":"noun","Meaning":" a device that supplies power ","Sentence":"Most cars run on a combination of power from a battery and gasoline."},{"Partofspeech":"noun","Meaning":"assault,beating","Sentence":"Her husband was accused of assault and battery after he attacked a man on the sidewalk."}]},{"Word":"beguile","Definitions":[{"Partofspeech":"verb","Meaning":"to trick, deceive","Sentence":"The thief beguiled his partners into surrendering all of their money to him."}]},{"Word":"behemoth ","Definitions":[{"Partofspeech":"noun","Meaning":"something of tremendous power or size","Sentence":"The new aircraft carrier is among several behemoths that the Air Force has added to its fleet."}]},{"Word":"benevolent","Definitions":[{"Partofspeech":"adjective","Meaning":"marked by goodness or doing good ","Sentence":"Police officers should be commended for their benevolent service to the community."}]},{"Word":"benign","Definitions":[{"Partofspeech":"adjective","Meaning":"favorable, not threatening, mild","Sentence":"We were all relieved to hear that the medical tests determined her tumor to be benign."}]},{"Word":"bequeath","Definitions":[{"Partofspeech":"verb","Meaning":"to pass on, give ","Sentence":"Jon’s father bequeathed his entire estate to his mother."}]},{"Word":"berate","Definitions":[{"Partofspeech":"verb","Meaning":"to scold vehemently","Sentence":"The angry boss berated his employees for failing to meet their deadline."}]},{"Word":"bereft","Definitions":[{"Partofspeech":"adjective","Meaning":"devoid of, without","Sentence":"His family was bereft of food and shelter following the tornado."}]},{"Word":"beseech","Definitions":[{"Partofspeech":"verb","Meaning":"to beg, plead, implore","Sentence":"The servant beseeched the king for food to feed his starving family."}]},{"Word":"bias","Definitions":[{"Partofspeech":"noun","Meaning":"a tendency, inclination, prejudice","Sentence":"The judge’s hidden bias against smokers led him to make an unfair decision."}]}]