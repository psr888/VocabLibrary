[{"Word":"covert","Definitions":[{"Partofspeech":"adj","Meaning":"secretly engaged in","Sentence":"Nerwin waged a covert campaign against his enemies while outwardly appearing to remain friendly."}]},{"Word":"credulity","Definitions":[{"Partofspeech":"noun","Meaning":"readiness to believe","Sentence":"His credulity made him an easy target for con men."}]},{"Word":"crescendo","Definitions":[{"Partofspeech":"noun","Meaning":"a steady increase in intensity or volume","Sentence":"The crescendo of the brass instruments gave the piece a patriotic feel."}]},{"Word":"criteria","Definitions":[{"Partofspeech":"noun","Meaning":"standards by which something is judged","Sentence":"Among Mrs. Fields’s criteria for good cookies are that they be moist and chewy."}]},{"Word":"culmination","Definitions":[{"Partofspeech":"noun","Meaning":"the climax toward which something progresses ","Sentence":"The culmination of the couple’s argument was the decision to divorce."}]},{"Word":"culpable","Definitions":[{"Partofspeech":"adj","Meaning":"deserving blame","Sentence":"He was culpable of the crime, and was sentenced to perform community service for 75 years."}]},{"Word":"cultivate","Definitions":[{"Partofspeech":"verb","Meaning":"to nurture, improve, refine","Sentence":"At the library, she cultivated her interest in spy novels."}]},{"Word":"cumulative","Definitions":[{"Partofspeech":"adj","Meaning":" increasing, building upon itself","Sentence":"The cumulative effect of hours spent in the sun was a deep tan."}]},{"Word":"cunning","Definitions":[{"Partofspeech":"adj","Meaning":"sly, clever at being deceitful ","Sentence":"The general devised a cunning plan to surprise the enemy."}]},{"Word":"cupidity","Definitions":[{"Partofspeech":"noun","Meaning":" greed, strong desire","Sentence":"His cupidity made him enter the abandoned gold mine despite the obvious dangers."}]},{"Word":"cursory","Definitions":[{"Partofspeech":"adj","Meaning":"brief to the point of being superficial","Sentence":"Late for the meeting, she cast a cursory glance at the agenda."}]},{"Word":"curt","Definitions":[{"Partofspeech":"adj","Meaning":"abruptly and rudely short","Sentence":"Her curt reply to my question made me realize that she was upset at me."}]},{"Word":"curtail ","Definitions":[{"Partofspeech":"verb","Meaning":"to lessen, reduce","Sentence":"Since losing his job, he had to curtail his spending."}]},{"Word":"daunting","Definitions":[{"Partofspeech":"adj","Meaning":"intimidating, causing one to lose courage","Sentence":"He kept delaying the daunting act of asking for a promotion."}]},{"Word":"dearth","Definitions":[{"Partofspeech":"noun","Meaning":"a lack, scarcity","Sentence":"An eager reader, she was dismayed by the dearth of classic books at the library."}]},{"Word":"debacle","Definitions":[{"Partofspeech":"noun","Meaning":" a disastrous failure, disruption","Sentence":"The elaborately designed fireworks show turned into a debacle when the fireworks started firing in random directions."}]}]