[{"Word":"debase","Definitions":[{"Partofspeech":"verb","Meaning":"to lower the quality or esteem of something ","Sentence":"The large raise that he gave himself debased his motives for running the charity."}]},{"Word":"debauch","Definitions":[{"Partofspeech":"verb","Meaning":"to corrupt by means of sensual pleasures ","Sentence":"An endless amount of good wine and cheese debauched the traveler."}]},{"Word":"debunk","Definitions":[{"Partofspeech":"verb","Meaning":" to expose the falseness of something","Sentence":"He debunked her claim to be the world’s greatest chess player by defeating her in 18 consecutive matches."}]},{"Word":"decorous","Definitions":[{"Partofspeech":"adjective","Meaning":"socially proper, appropriate","Sentence":"The appreciative guest displayed decorous behavior toward his host."}]},{"Word":"decry","Definitions":[{"Partofspeech":"verb","Meaning":"to criticize openly","Sentence":"The kind video rental clerk decried the policy of charging customers' late fees."}]},{"Word":"deface","Definitions":[{"Partofspeech":"verb","Meaning":" to ruin or injure something’s appearance","Sentence":"The brothers used eggs and shaving cream to deface their neighbor’s mailbox."}]},{"Word":"defamatory","Definitions":[{"Partofspeech":"adj","Meaning":"harmful toward another’s reputation","Sentence":"The defamatory gossip spreading about the actor made the public less willing to see the actor’s new movie."}]},{"Word":"defer","Definitions":[{"Partofspeech":"verb","Meaning":"to postpone something; to yield to another’s wisdom","Sentence":"(Ron deferred to Diane, the expert on musical instruments, when he was asked about buying a piano."}]},{"Word":"deferential","Definitions":[{"Partofspeech":"adj","Meaning":" showing respect for another’s authority","Sentence":"His deferential attitude toward her made her more confident in her ability to run the company."}]},{"Word":"defile","Definitions":[{"Partofspeech":"verb","Meaning":"to make unclean, impure","Sentence":"(She defiled the calm of the religious building by playing her banjo.)"}]},{"Word":"deft","Definitions":[{"Partofspeech":"adj","Meaning":"skillful, capable","Sentence":"Having worked in a bakery for many years, Marcus was a into a community center."}]},{"Word":"defunct","Definitions":[{"Partofspeech":"no longer used or existing","Meaning":"They planned to turn the defunct schoolhouse into a community center.","Sentence":"v"}]},{"Word":"deleterious","Definitions":[{"Partofspeech":"adj","Meaning":"harmful","Sentence":"She experienced the deleterious effects of running a marathon without stretching her muscles enough beforehand."}]},{"Word":"deliberate","Definitions":[{"Partofspeech":"adj","Meaning":" intentional, reflecting careful consideration","Sentence":"Though Mary was quite upset, her actions to resolve the dispute were deliberate."}]},{"Word":"delineate","Definitions":[{"Partofspeech":"verb","Meaning":"to describe, outline, and shed light on","Sentence":"She neatly delineated her reasons for canceling the project’s funding."}]}]