[{"Word":"conundrum","Definitions":[{"Partofspeech":"noun","Meaning":"puzzle, problem","Sentence":"Interpreting Jane’s behavior was a constant conundrum."}]},{"Word":"convene","Definitions":[{"Partofspeech":"verb","Meaning":"to call together","Sentence":"Jason convened his entire extended family for a discussion."}]},{"Word":"convention","Definitions":[{"Partofspeech":"noun","Meaning":"an assembly of people","Sentence":"The hotel was full because of the cattle ranchers’ convention."},{"Partofspeech":"noun","Meaning":"a rule, custom","Sentence":"The cattle-ranchers have a convention that you take off your boots before entering their houses."}]},{"Word":"convivial ","Definitions":[{"Partofspeech":"adj","Meaning":"characterized by feasting, drinking, merriment","Sentence":"The restaurant’s convivial atmosphere put me immediately at ease."}]},{"Word":"convoluted ","Definitions":[{"Partofspeech":"adj","Meaning":"intricate, complicated ","Sentence":"Grace’s story was so convoluted that I couldn’t follow it."}]},{"Word":"copious","Definitions":[{"Partofspeech":"adj","Meaning":"profuse, abundant","Sentence":"Copious amounts of Snapple were imbibed in the cafeteria."}]},{"Word":"cordial","Definitions":[{"Partofspeech":"adj","Meaning":"warm, affectionate ","Sentence":"His cordial greeting melted my anger at once."}]},{"Word":"coronation","Definitions":[{"Partofspeech":"noun","Meaning":"the act of crowning","Sentence":"The new king’s coronation occurred the day after his father’s death."}]},{"Word":"corpulence","Definitions":[{"Partofspeech":"adj","Meaning":"extreme fatness","Sentence":"Henry’s corpulence did not make him any less attractive to his charming, svelte wife."}]},{"Word":"corroborate","Definitions":[{"Partofspeech":"verb","Meaning":"to support with evidence","Sentence":"Luke’s seemingly outrageous claim was corroborated by witnesses."}]},{"Word":"corrosive ","Definitions":[{"Partofspeech":"adj","Meaning":"having the tendency to erode or eat away","Sentence":"The effect of the chemical was highly corrosive."}]},{"Word":"cosmopolitan","Definitions":[{"Partofspeech":"adj","Meaning":"sophisticated, worldly","Sentence":"Lloyd’s education and upbringing were cosmopolitan, so he felt right at home among the powerful and learned."}]},{"Word":"counteract","Definitions":[{"Partofspeech":"verb","Meaning":"to neutralize, make ineffective","Sentence":"The antidote counteracted the effect of the poison."}]},{"Word":"coup ","Definitions":[{"Partofspeech":"noun","Meaning":"a brilliant, unexpected act","Sentence":"Alexander pulled off an amazing coup when he got a date with Cynthia by purposely getting hit by her car"},{"Partofspeech":"noun","Meaning":" the overthrow of a government and assumption of authority","Sentence":"In their coup attempt, the army officers stormed the Parliament and took all the legislators hostage."}]},{"Word":"covet","Definitions":[{"Partofspeech":"verb","Meaning":"to desire enviously","Sentence":"I coveted Moses’s house, wife, and car."}]}]